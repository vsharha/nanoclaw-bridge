# ── LLM Proxy (claude-code-proxy) ─────────────────────────────────────────
# Provider: openai | google | anthropic
PREFERRED_PROVIDER=openai

# Models to use (mapped from claude-sonnet → BIG_MODEL, claude-haiku → SMALL_MODEL)
BIG_MODEL=gpt-4.1
SMALL_MODEL=gpt-4.1-mini

# API keys — set only the key(s) for your provider
OPENAI_API_KEY=
OPENAI_BASE_URL=          # leave blank for OpenAI; set to https://openrouter.ai/api/v1 for OpenRouter
GEMINI_API_KEY=
ANTHROPIC_API_KEY=        # only if PREFERRED_PROVIDER=anthropic

# ── NanoClaw ───────────────────────────────────────────────────────────────
ASSISTANT_NAME=Andy

# ── Messaging Channels ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
DISCORD_BOT_TOKEN=
WHATSAPP_ENABLE=
WHATSAPP_PHONE_NUMBER=    # required for pairing code auth (include country code, no +, e.g. 1234567890)

# ── Auto-Registration (optional) ───────────────────────────────────────────
# Pre-register a main chat on startup (so NanoClaw responds immediately)
# JID format: Telegram=tg:<chat_id>  Slack=slack:<channel_id>  Discord=dc:<channel_id>
NANOCLAW_MAIN_JID=
NANOCLAW_MAIN_CHANNEL=telegram
NANOCLAW_MAIN_NAME=Main

# ── Host Filesystem Access ──────────────────────────────────────────────────
# Path on the HOST that the agent container can read/write.
# Use / to give access to your full filesystem (recommended for full independence).
# Use /home/youruser to restrict to your home directory only.
# Must be the same path on both host and container (DinD requirement).
# Agent sees it at /workspace/extra/host (if /) or /workspace/extra/home (if home dir).
# ~ inside the agent will resolve to /workspace/extra/host/home/$HOST_USER (or /workspace/extra/home).
NANOCLAW_AGENT_HOME=/
HOST_USER=youruser
# When NANOCLAW_AGENT_HOME=/ leave this unset (/ always exists in container).
# When NANOCLAW_AGENT_HOME=/home/youruser set this to /home/youruser so nanoclaw can validate the path.
# NANOCLAW_AGENT_MOUNT_PATH=/home/youruser

# Host path for NanoClaw's data directory. Must be identical on host and container
# so Docker-in-Docker volume mounts resolve correctly.
NANOCLAW_DATA_DIR=/var/lib/nanoclaw

# ── Advanced ───────────────────────────────────────────────────────────────
CONTAINER_IMAGE=nanoclaw-agent:latest
CONTAINER_TIMEOUT=1800000
IDLE_TIMEOUT=1800000
MAX_CONCURRENT_CONTAINERS=5
